# Copy this to .env and fill in real values:
#   cp .env.example .env
#
# docker compose reads .env automatically from the project root.
# Every var marked (required) has no fallback — the relevant binary
# refuses to start without it on purpose.

# ---- Metasploit RPC (talon-strike, kali-msf) ----
MSF_PASSWORD=change-me-to-a-real-password        # (required)
MSF_PORT=5554
MSF_SSL=true
# When running host-side binaries against compose MSF, use:
# MSF_SERVER=localhost

# ---- Reverse payload defaults (strike injects if agent omits them) ----
LHOST=127.0.0.1
LPORT=4444

# ---- Talon Arsenal Engine ----
HEXSTRIKE_PORT=8888

# ---- RabbitMQ (talon-relay) ----
RABBITMQ_USER=talon
RABBITMQ_PASSWORD=change-me-to-a-real-password   # (required)
AMQP_URL=amqp://talon:change-me-to-a-real-password@localhost:5672/  # (required)

# ---- Lab vuln target (compose --profile vuln) ----
# One Dockerfile, two targets: real (default) | mimic
# VULN_TARGET=real
# VULN_TARGET_IMAGE=talon-vuln-target
# Python mimic (recon only, no real MSF session):
# VULN_TARGET=mimic

# ============================================================================
# LLM provider — pick ONE backend per role. See README.
#   LLM_PROVIDER:      bedrock (default) | ollama | openai
#   LLM_CODE_PROVIDER: optional override for codegen only
# ============================================================================
LLM_PROVIDER=bedrock
LLM_CODE_PROVIDER=
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1000
# Wall-clock budget for one agent run segment (core).
# TALON_RUN_TIMEOUT=20m
# HTTP client timeout for OpenAI-compatible providers.
# OPENAI_HTTP_TIMEOUT=120s

# ---- Ollama (LLM_PROVIDER=ollama) ----
# ollama create talon -f models/Modelfile
OLLAMA_URL=http://localhost:11434
OLLAMA_MAIN_MODEL=talon
OLLAMA_JUDGE_MODEL=talon
OLLAMA_CODE_MODEL=talon

# ---- OpenAI-compatible (LLM_PROVIDER=openai) ----
# OpenAI, Azure OpenAI, z.ai/GLM, vLLM, LiteLLM, etc.
OPENAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
OPENAI_API_KEY=                                # (required if provider=openai)
OPENAI_MAIN_MODEL=glm-5.2
OPENAI_JUDGE_MODEL=glm-5.2
OPENAI_CODE_MODEL=glm-5.2

# ---- AWS Bedrock (LLM_PROVIDER=bedrock) ----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ---- Operator CLI (optional) ----
# TALON_CORE_URL=http://localhost:8000
# TALON_PROJECT_DIR=.
# TALON_OUTPUT=table
# TALON_CONFIG=~/.config/talon/config.yaml
