# Copy this to .env and fill in real values:
#   cp .env.example .env
#
# docker compose reads .env automatically from the project root.
# Every var marked (required) has no fallback -- the relevant binary
# refuses to start without it, on purpose. Don't add a default back.

# ---- Metasploit RPC (talon-strike, kali-msf) ----
MSF_PASSWORD=change-me-to-a-real-password        # (required)
MSF_PORT=5554
MSF_SSL=true

# ---- Talon Arsenal Engine (talon-arsenal) ----
HEXSTRIKE_PORT=8888

# ---- RabbitMQ (talon-relay) ----
RABBITMQ_USER=talon
RABBITMQ_PASSWORD=change-me-to-a-real-password   # (required)
# Must match RABBITMQ_USER/RABBITMQ_PASSWORD above and the rabbitmq
# service's host-network port (5672).
AMQP_URL=amqp://talon:change-me-to-a-real-password@localhost:5672/  # (required)

# ============================================================================
# LLM provider -- pick ONE backend per role. See README "Configuration
# Reference" for the full matrix.
#   LLM_PROVIDER:    bedrock (default) | ollama | openai
#   LLM_CODE_PROVIDER: optional override for the codegen role ONLY, so you can
#                      run e.g. the orchestrator on a hosted provider and
#                      codegen on a local uncensored model:
#                        LLM_PROVIDER=openai
#                        LLM_CODE_PROVIDER=ollama
# ============================================================================
LLM_PROVIDER=bedrock
LLM_CODE_PROVIDER=
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1000

# ---- Ollama (LLM_PROVIDER=ollama, or LLM_CODE_PROVIDER=ollama) ----
# Build the local model first:  ollama create talon -f models/Modelfile
OLLAMA_URL=http://localhost:11434
OLLAMA_MAIN_MODEL=talon
OLLAMA_JUDGE_MODEL=talon
OLLAMA_CODE_MODEL=talon

# ---- OpenAI-compatible (LLM_PROVIDER=openai) ----
# Any /chat/completions endpoint: OpenAI, Azure OpenAI, z.ai/GLM, vLLM, LiteLLM.
# GLM-5.2 via z.ai's coding PaaS is shown. (required when provider=openai)
OPENAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
OPENAI_API_KEY=                                # (required if provider=openai)
OPENAI_MAIN_MODEL=glm-5.2
OPENAI_JUDGE_MODEL=glm-5.2
OPENAI_CODE_MODEL=glm-5.2

# ---- AWS Bedrock (LLM_PROVIDER=bedrock; the default) ----
AWS_REGION=us-east-1
# Leave these blank and instead mount ~/.aws into the containers, or run
# on an EC2 instance with an IAM role, if you'd rather not put long-lived
# keys in this file at all.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
